# =============================================================================
# Polymarket Bot Configuration
# =============================================================================

# IMPORTANT: Polymarket uses USDC on Polygon (NOT USDT)
# Trading on CLOB is off-chain - NO gas fees required for placing/canceling orders
#
# Gas Fees (POL - Polygon's native token):
# - Self-managed wallet (MetaMask): Small amount (~$0.10) needed ONLY for initial token approvals
# - Email/Google signup: Polymarket covers ALL gas costs via proxy wallet (completely free)

# -----------------------------------------------------------------------------
# Wallet Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Your Polygon wallet private key (get from MetaMask: Settings > Security > Show Private Key)
# WARNING: Keep this secret! Never commit to Git!
WALLET_PRIVATE_KEY=your_private_key_here

# Polygon RPC endpoint (choose one):
# - Public (free): https://polygon-rpc.com
# - Alchemy: https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# - Infura: https://polygon-mainnet.infura.io/v3/YOUR_API_KEY
POLYGON_RPC_URL=https://polygon-rpc.com

# -----------------------------------------------------------------------------
# Polymarket API (Optional - for authenticated trading)
# -----------------------------------------------------------------------------
# Get API key from Polymarket if you have access
# Most features work without API key (read-only)
POLYMARKET_API_KEY=

# -----------------------------------------------------------------------------
# Exchange Price Feeds (Optional)
# -----------------------------------------------------------------------------
# Used for arbitrage detection - no API key needed for public WebSocket feeds
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com

# -----------------------------------------------------------------------------
# Database (Optional - for trade history storage)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/polymarket_bot

# -----------------------------------------------------------------------------
# Bot Trading Parameters (can also be set in config.yaml)
# -----------------------------------------------------------------------------
INITIAL_BET_USDC=0.5           # Starting bet size in USDC
PROFIT_INCREASE_PCT=10         # % of profit to add after wins
MAX_DAILY_LOSS_PCT=20          # Daily loss limit
CIRCUIT_BREAKER_LOSS=5         # Auto-stop after X consecutive losses

# -----------------------------------------------------------------------------
# Monitoring (Optional)
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# =============================================================================
# Quick Start Checklist:
# =============================================================================
# 1. ✅ Set WALLET_PRIVATE_KEY (from MetaMask)
# 2. ✅ Set POLYGON_RPC_URL (or use default)
# 3. ✅ Ensure wallet has USDC on Polygon
# 4. ✅ Optional: Set INITIAL_BET_USDC (or use config.yaml)
# 5. ✅ Run: python -m src
# =============================================================================
